# Copy to .env.local for development. Set the same keys in Vercel → Project → Settings → Environment Variables.

# --- Public (safe to expose in browser) ---
# Canonical site: https://www.thebacup.com (use HTTPS in production; Vercel redirects HTTP → HTTPS)
NEXT_PUBLIC_APP_URL=https://www.thebacup.com
# Optional: only if app auth lives on a different host than marketing (e.g. app. subdomain). Must match Supabase Auth redirect URLs and cookie domain.
# NEXT_PUBLIC_APP_ORIGIN=https://app.thebacup.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth redirect bases (must match URLs registered in Google Cloud / Azure)
# Google: https://www.thebacup.com/api/integrations/google/callback
# Microsoft: https://www.thebacup.com/api/integrations/microsoft/callback
# ========== Where to connect what ==========
#
# 1) VERCEL — Project → Settings → Environment Variables (Production + Preview)
#    Required for middleware + auth (without these you get MIDDLEWARE_INVOCATION_FAILED on deploy):
#      NEXT_PUBLIC_SUPABASE_URL
#      NEXT_PUBLIC_SUPABASE_ANON_KEY
#    Also set (same values as local .env.local where applicable):
#      NEXT_PUBLIC_APP_URL=https://www.thebacup.com
#      GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, SUPABASE_SERVICE_ROLE_KEY, etc.
#
# 2) SUPABASE — Dashboard → Authentication → URL configuration
#    Site URL: https://www.thebacup.com  (production)
#    Redirect URLs — add EVERY host where users sign in (exact paths):
#      https://www.thebacup.com/auth/callback
#      https://YOUR-PROJECT.vercel.app/auth/callback   ← e.g. bacup-3.vercel.app (production deploy URL)
#      https://YOUR-PROJECT-git-main-ORG.vercel.app/auth/callback   ← preview pattern if you use it
#      http://localhost:3000/auth/callback
#
# 3) GOOGLE CLOUD — APIs & Services → Credentials → your OAuth client
#    Authorized redirect URIs:
#      https://www.thebacup.com/api/integrations/google/callback
#      (add Vercel URL too if you test Gmail/Calendar on *.vercel.app)
#
# --- Supabase → Authentication → URL configuration (detail) ---
# Site URL (production):     https://www.thebacup.com
# Site URL (local dev):       http://localhost:3000
# Redirect URLs (add each line exactly; OAuth will fail if missing):
#   https://www.thebacup.com/auth/callback
#   http://localhost:3000/auth/callback
# Optional (127.0.0.1 / preview): http://127.0.0.1:3000/auth/callback
# If you use a separate app host, also add: https://YOUR-APP-HOST/auth/callback
# Wildcard (Supabase supports *): https://www.thebacup.com/*  — only if your project allows it; exact /auth/callback is safest.

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Deepgram browser key only if using client-side voice (optional; server uses DEEPGRAM_API_KEY)
# NEXT_PUBLIC_DEEPGRAM_API_KEY=

# --- Server only (never commit real values) ---
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
ASK_BACUP_MODEL=gpt-4o-mini

DEEPGRAM_API_KEY=

# Google OAuth (Gmail, Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Or: GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_STATE_SECRET=
# Optional override; default redirect built from NEXT_PUBLIC_APP_URL
# GOOGLE_OAUTH_REDIRECT_URI=https://www.thebacup.com/api/integrations/google/callback

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Or MICROSOFT_OAUTH_* variants — see src/lib/integrations/microsoft/microsoftEnv.ts

# Ask Bacup web search (optional; at least one for live web excerpts)
TAVILY_API_KEY=
# SERPER_API_KEY=

# Cron (Vercel Cron hits GET /api/cron/recurrence-reconcile with Bearer CRON_SECRET)
CRON_SECRET=
