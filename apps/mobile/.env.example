# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* automatically).
# Use the same Supabase project as the Next.js web app (see web `.env.local`).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mobile OAuth (public client IDs only)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# Server (.env.local): set GOOGLE_MOBILE_OAUTH_CLIENT_ID to this same value so `/api/mobile/...` can refresh Gmail tokens.
EXPO_PUBLIC_MICROSOFT_OAUTH_CLIENT_ID=
EXPO_PUBLIC_MICROSOFT_TENANT_ID=common
